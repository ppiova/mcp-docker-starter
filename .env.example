# ---- Azure OpenAI (required for the agent-client service) ----
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Optional — if set, the agent uses API key auth (simplest inside containers).
# Leave empty to fall back to AzureCliCredential / DefaultAzureCredential.
AZURE_OPENAI_API_KEY=

# Override if you expose the MCP server on a different host/port
# (the default points to the compose service name)
# MCP_SERVER_URL=http://mcp-server:8000/mcp
